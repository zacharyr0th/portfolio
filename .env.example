# API Configuration
API_URL=http://localhost:3000/api
APP_URL=http://localhost:3000

# Chain Configuration
DEFAULT_CHAIN=aptos

# RPC Endpoints (Mainnet)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=example_api_key
APTOS_RPC_URL=https://fullnode.mainnet.aptoslabs.com/v1
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
BASE_RPC_URL=https://mainnet.base.org

# Market Data API Keys
FINNHUB_API_KEY=your_finnhub_api_key
CMC_API_KEY=your_cmc_api_key

# Exchange API Keys
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_PRIVATE_KEY=your_kraken_private_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_SECRET=your_gemini_api_secret

# Banking Integration
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret

# Coinbase API Credentials
COINBASE_API_KEY=your_api_key_here
COINBASE_SECRET_KEY=your_secret_key_here
COINBASE_API_SECRET=your_api_secret_here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_MAX_AGE=86400

# Logging Configuration
LOG_LEVEL=info # debug, info, warn, error

# Wallet Public Keys 

# Solana Wallets
SOLANA_WALLET_change-this-name=your_solana_wallet_address

# Aptos Wallets
APTOS_WALLET_change-this-name=your_aptos_wallet_address

# Sui Wallets
SUI_WALLET_change-this-name=your_sui_wallet_address 